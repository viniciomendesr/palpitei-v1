build/

# Secrets — NEVER commit
.env
.env.local
.env.*.local
!.env.example

# HTTPS dev certificate: localhost-key.pem is a PRIVATE KEY. It is generated by
# `npm run dev:https` (scripts/dev-cert.mjs) and is specific to this machine — the
# SAN carries the network IPs of whoever generated it. It is useless to anyone
# else and must not be committed.
apps/web/certificates/

# TxLINE data: T&C §7 licenses the data for the hackathon only and PROHIBITS
# redistribution. No payloads in the public repo. The match cache lives in Postgres.
.cache/
*.txline-state.json
supabase/.temp/

.DS_Store
*.log
npm-debug.log*
.turbo/
coverage/

# tsc build artifact — do not commit.
*.tsbuildinfo

# Agent worktrees: working copies, not part of the project.
.claude/worktrees/

# Internal agent instructions and records: these stay local and are not part of
