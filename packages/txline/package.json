{
  "name": "@palpitei/txline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Palpitei txline — TxLINE client (auth, REST, /updates) and ingest layer (live SSE, replay, dev-only synthetic generator). The game's primary source.",
  "engines": {
    "node": ">=22.6.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
