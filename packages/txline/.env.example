# @palpitei/txline — copie as variáveis necessárias para o .env da aplicação.
# Mantenha todos os valores da mesma rede; a biblioteca não carrega `.env` sozinha.

# TxLINE (devnet)
TXLINE_API_ORIGIN=https://txline-dev.txodds.com

# Derivados de `TXLINE_API_ORIGIN` se vazios.
#   TXLINE_API_BASE_URL = ${TXLINE_API_ORIGIN}/api
#   TXLINE_JWT_URL      = ${TXLINE_API_ORIGIN}/auth/guest/start
# TXLINE_API_BASE_URL=
# TXLINE_JWT_URL=

# Credenciais do serviço — nunca exponha ao cliente ou ao repositório.
# `TXLINE_API_TOKEN` é obrigatório para endpoints de dados.
TXLINE_API_TOKEN=

# JWT guest opcional; vazio inicia e renova uma sessão automaticamente.
TXLINE_JWT=

# Dados
# 72 = World Cup; vazio busca tudo e filtra por nome.
TXLINE_COMPETITION_ID=72

# Timeout de cada requisição HTTP, em ms.
TXLINE_HTTP_TIMEOUT_MS=20000

# Varredura de `/updates`: 12 intervalos de cinco minutos por hora.
TXLINE_SWEEP_CONCURRENCY=4

# Janela varrida em volta do kickoff, em horas.
TXLINE_SWEEP_HOURS_BEFORE=1
TXLINE_SWEEP_HOURS_AFTER=4

# Ingestão: `true` conecta aos streams SSE; `false` usa replay e snapshots.
TXLINE_LIVE_INGEST=true

# Velocidade padrão do replay (60 = 1 min de jogo por segundo real).
REPLAY_SPEED=60

# Gerador sintético (somente desenvolvimento).
# ATENÇÃO: nunca habilite em demo/submissão; a UI deve declarar a origem synthetic.
TXLINE_ALLOW_SYNTHETIC=false

# Diagnóstico: silencia console, mas preserva o buffer de logs.
TXLINE_LOG_SILENT=false
