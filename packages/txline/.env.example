# ============================================================================
# @palpitei/txline — variáveis de ambiente. Copie para .env e ajuste.
#
# Regra herdada do spike: TODOS os valores da MESMA rede (devnet com devnet).
# Este pacote NÃO carrega .env sozinho (biblioteca que mexe no ambiente do
# processo é surpresa) — quem carrega é a app; os scripts usam o
# --env-file-if-exists do Node.
# ============================================================================

# ----------------------------------------------------------------------------
# TxLINE — endereços (DEVNET)
# ----------------------------------------------------------------------------

# Origem da API. Padrão: devnet, a rede do hackathon.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com

# Derivados da origem se vazios. Só preencha para apontar fora do padrão.
#   TXLINE_API_BASE_URL = ${TXLINE_API_ORIGIN}/api
#   TXLINE_JWT_URL      = ${TXLINE_API_ORIGIN}/auth/guest/start
# TXLINE_API_BASE_URL=
# TXLINE_JWT_URL=

# ----------------------------------------------------------------------------
# TxLINE — credenciais do SERVIÇO
#
# Isto é o Palpitei se apresentando para a TxLINE: credencial única do processo,
# igual para todo mundo. NÃO é a identidade do fã — essa é o privy_did
# verificado, e nunca vem do corpo da requisição.
# ----------------------------------------------------------------------------

# Token de assinatura (X-Api-Token), emitido pelo credenciamento on-chain
# (wallet -> subscribe -> activate), feito UMA vez fora do webapp.
# OBRIGATÓRIO: sem ele os endpoints de dados respondem 401/403 e o guest JWT
# sozinho não abre o feed. Segredo — nunca vai para o client nem para o repo.
TXLINE_API_TOKEN=

# Guest JWT de partida (opcional). Vazio = o cliente abre uma sessão guest
# sozinho no primeiro uso e renova automaticamente no 401. Preencher só serve
# para reaproveitar uma sessão que você já tem.
TXLINE_JWT=

# ----------------------------------------------------------------------------
# Dados
# ----------------------------------------------------------------------------

# competitionId do snapshot de fixtures. 72 = World Cup.
# VAZIO (TXLINE_COMPETITION_ID=) = busca tudo e filtra por "World Cup".
TXLINE_COMPETITION_ID=72

# Timeout de cada requisição HTTP, em ms.
TXLINE_HTTP_TIMEOUT_MS=20000

# --- varredura de /updates (a linha do tempo REAL) ---
# /{feed}/updates/{epochDay}/{hora}/{intervalo} varre baldes de 5 min: 12 por
# hora (0..11) — varrer só 0..9 perde 10 min por hora EM SILÊNCIO.
# São ~144 requisições por partida; a concorrência abaixo é o quanto vai em voo
# ao mesmo tempo. Conservador de propósito (a devnet não gosta de rajada).
TXLINE_SWEEP_CONCURRENCY=4

# Janela varrida em volta do kickoff, em horas.
TXLINE_SWEEP_HOURS_BEFORE=1
TXLINE_SWEEP_HOURS_AFTER=4

# ----------------------------------------------------------------------------
# Ingestão
# ----------------------------------------------------------------------------

# true (padrão) = conecta nos streams SSE de scores/odds ao subir.
# false = só replay/snapshots (útil offline).
# ⚠️ Este caminho NUNCA processou um evento real (A7): os streams só foram
# vistos "abertos com 0 eventos". "open / 0 eventos" não é sucesso — só
# `normalizados > 0` prova que ele vive.
TXLINE_LIVE_INGEST=true

# Velocidade padrão do replay (60 = 1 min de jogo por segundo real).
REPLAY_SPEED=60

# ----------------------------------------------------------------------------
# Gerador sintético — DEV-ONLY
# ----------------------------------------------------------------------------

# true liga o replay sintético (partida inventada, determinística por fixtureId)
# quando a devnet não tem dados da fixture.
#
# ⚠️ NUNCA em demo/submissão. A regra do hackathon exige a TxLINE como fonte
# primária/ao vivo, e o "simulado" que o critério aceita é o feed simulado DA
# TxLINE (os replays da devnet), não um gerador nosso. Se ligar em dev, o badge
# da sala TEM de mostrar "synthetic" — badge que mente sobre a origem do dado é
# pior que badge nenhum.
TXLINE_ALLOW_SYNTHETIC=false

# ----------------------------------------------------------------------------
# Diagnóstico
# ----------------------------------------------------------------------------

# true silencia o console (o ring buffer de recentLogs() continua gravando).
# Os testes usam isto.
TXLINE_LOG_SILENT=false
