{
  "name": "@palpitei/selo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Palpitei selo — the Selo TxLINE: metadata, the TxODDS anchor on Solana and the one-off minting script. Nothing here runs in the app runtime.",
  "engines": {
    "node": ">=22.6.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./metadata": "./src/metadata.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "selo:mint": "node --experimental-strip-types --env-file-if-exists=../../.env scripts/mint-selo.ts"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-core": "^1.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@palpitei/db": "*",
    "@palpitei/txline": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.2"
  }
}
