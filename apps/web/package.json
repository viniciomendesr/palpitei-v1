{
  "name": "@palpitei/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PWA do Palpitei — telas do mockup sobre o design system vendorizado.",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:https": "node ../../scripts/dev-cert.mjs && next dev -H 0.0.0.0 -p 3000 --experimental-https --experimental-https-key ./certificates/localhost-key.pem --experimental-https-cert ./certificates/localhost.pem",
    "dev:local": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@palpitei/db": "*",
    "@palpitei/ds": "*",
    "@palpitei/txline": "*",
    "@privy-io/react-auth": "^3.35.1",
    "@privy-io/server-auth": "^1.32.5",
    "@solana-program/memo": "^0.10.0",
    "@solana-program/system": "^0.10.0",
    "@solana-program/token": "^0.9.0",
    "dotenv": "^16.6.1",
    "next": "^15.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.7.3"
  }
}
