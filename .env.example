# Copy to .env. Never commit PRIVY_APP_SECRET, TxLINE, or DATABASE_URL.

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=cmrnum7sz00ft0cjruc4dtkj2
PRIVY_APP_SECRET=

# Configure Google, Solana, `users-without-wallets`, and Allowed Origins in Privy.
# To validate the configuration and the OAuth redirect, run `npm run privy:doctor`.

# TxLINE — server-side credentials only
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=
# 72 = World Cup; empty fetches and filters by name.
TXLINE_COMPETITION_ID=72

# Database — Supabase is just Postgres; identity comes from the Privy DID.
# Use the `postgres` role URI and run `npm run db:migrate` before starting.
# Prefer the pooler on port 6543; RLS without a policy requires the schema owner role.
DATABASE_URL=

# Local Postgres example. Tests use PGlite and do not need this.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/palpitei

# Optional: CA for full verification of the remote TLS certificate.
# DATABASE_CA_CERT=./certs/supabase-ca.crt

# Runtime
# The server only starts live ingestion when the value is exactly `true`.
TXLINE_LIVE_INGEST=false
# Live fixtures, comma-separated; the legacy `LIVE_FIXTURE_ID` is still accepted.
LIVE_FIXTURE_IDS=
# Match seconds per real second; 12 preserves the replay's minimum windows.
REPLAY_SPEED=12
# WARNING: the synthetic generator is development-only and must never ship.
TXLINE_ALLOW_SYNTHETIC=false
