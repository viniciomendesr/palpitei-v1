# Copie para .env. Nunca versione PRIVY_APP_SECRET, TxLINE ou DATABASE_URL.

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=cmrnum7sz00ft0cjruc4dtkj2
PRIVY_APP_SECRET=

# Configure Google, Solana, `users-without-wallets` e Allowed Origins no Privy.
# Para validar a configuração e o redirect OAuth, rode `npm run privy:doctor`.

# TxLINE — credenciais somente do servidor
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=
# 72 = World Cup; vazio busca e filtra por nome.
TXLINE_COMPETITION_ID=72

# Banco — Supabase é apenas Postgres; a identidade vem do DID da Privy.
# Use a URI da role `postgres` e execute `npm run db:migrate` antes de iniciar.
# Prefira a porta 6543 do pooler; RLS sem policy exige a role dona do schema.
DATABASE_URL=

# Exemplo de Postgres local. Os testes usam PGlite sem esta configuração.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/palpitei

# Opcional: CA para verificar integralmente o certificado TLS remoto.
# DATABASE_CA_CERT=./certs/supabase-ca.crt

# Runtime
# O servidor só inicia ingestão ao vivo quando o valor é exatamente `true`.
TXLINE_LIVE_INGEST=false
# Fixtures ao vivo, separadas por vírgula; `LIVE_FIXTURE_ID` legado ainda é aceito.
LIVE_FIXTURE_IDS=
# Segundos de jogo por segundo real; 12 preserva janelas mínimas do replay.
REPLAY_SPEED=12
# ATENÇÃO: gerador sintético é somente desenvolvimento e nunca pode ir à submissão.
TXLINE_ALLOW_SYNTHETIC=false
